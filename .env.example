# TalentFlow ATS — 企业部署环境变量
# 复制为 .env 后填写：cp .env.example .env

# DeepSeek / OpenAI 兼容 API（AI 匹配、面试、JD Copilot）
AI_API_KEY=

# 首次部署可设为 true 写入演示账号与岗位；生产上线后改为 false
SEED_DEMO_DATA=true

# MySQL（docker-compose 内置，一般无需改）
DB_PASSWORD=talentflow_secret

# 允许访问 API 的前端域名（逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:80,https://*.vercel.app
